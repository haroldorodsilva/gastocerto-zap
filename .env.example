# Database
DATABASE_URL="postgresql://postgres:12345@localhost:5432/zap?schema=public"

# CORS — origens permitidas (separadas por vírgula, use * para liberar tudo em dev)
# Em produção, liste os domínios do admin e do front:
# CORS_ORIGINS=https://admin.seudominio.com.br,https://app.seudominio.com.br
CORS_ORIGINS=*

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_KEY_PREFIX=dev
# OU usar configuração individual:
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=""

# ServerDEV_AUTH_BYPASS
NODE_ENV="development"
PORT=3000

# ===============================================
# Coolify Healthcheck Configuration
# ===============================================
# URL: /health
# Intervalo: 10 segundos
# Timeout: 5 segundos
# Tentativas: 3 vezes
# ===============================================

# Baileys WhatsApp
QR_TIMEOUT_MS=120000
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_INTERVAL_MS=10000

# ===============================================
# AI Provider API Keys
# ===============================================
# OpenAI - https://platform.openai.com/api-keys
# OPENAI_API_KEY=""

# Google Gemini - https://aistudio.google.com/api-keys  
# GOOGLE_AI_API_KEY=""

# Groq (GRÁTIS) - https://console.groq.com/keys
# GROQ_API_KEY=""

# DeepSeek - https://platform.deepseek.com/api-keys
# DEEPSEEK_API_KEY=""
# ===============================================

# Gasto Certo API
# ⚠️  Use a URL DIRETA do serviço (Render/Coolify), NÃO o gateway público (APISIX/Cloudflare).
# O gateway público descarta headers customizados de autenticação HMAC (x-timestamp, x-signature).
# Dev:  http://localhost:3333/api
# HLG:  https://gastocerto-api-hlg.onrender.com/api
# Prod: https://gastocerto-api.onrender.com/api
GASTO_CERTO_API_URL="http://localhost:3333/api"
SERVICE_SHARED_SECRET=""
SERVICE_REQUEST_TIMEOUT_MS="300000"

# Security
# Chave de criptografia para API keys no banco de dados (AES-256-GCM)
# Gere com: openssl rand -hex 32
# Se não definida, API keys serão armazenadas em plaintext
ENCRYPTION_KEY=""
# Salt para derivação da chave criptográfica (scrypt)
# Em produção, gere um valor único com: openssl rand -hex 16
# Se não definido, usa salt padrão interno (aceitável em dev)
ENCRYPTION_SALT="gastocerto-salt-default"

# Test Mode - Deixe vazio para processar todas as mensagens
# Preencha com número de teste para processar apenas mensagens desse número
# Formato: 5511999999999 (só números, sem +)
TEST_PHONE_NUMBER=5566996285154

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# User Rate Limiting (anti-spam por usuário, via Redis)
USER_RATE_LIMIT_PER_MINUTE=10
USER_RATE_LIMIT_PER_HOUR=100
USER_RATE_LIMIT_PER_DAY=500

# Telegram Mode (polling = dev, webhook = prod)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=

# Confirmation & Onboarding Timeouts
CONFIRMATION_TIMEOUT_SECONDS=300000
ONBOARDING_TIMEOUT_MS=1800000

# Transaction Confirmation Settings
REQUIRE_CONFIRMATION=true           # true = sempre pede confirmação | false = nunca pede

# ⚠️  Thresholds (autoRegisterThreshold, minConfidenceThreshold) 
# agora estão no banco de dados (tabela ai_settings)
# Configure via SQL ou Prisma Studio


